{
  "name": "class-points-manager",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.js",
  "type": "module",
  "description": "教师端轻量化班级积分管理系统 - 本地运行、语音交互、无网络依赖",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5",
    "recharts": "^2.10.3",
    "idb": "^8.0.0",
    "lucide-react": "^0.294.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.classpoints.manager",
    "productName": "班级积分管理",
    "directories": { "output": "dist-electron" },
    "files": ["dist/**", "electron/**"],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg", "category": "public.app-category.education" }
  }
}
