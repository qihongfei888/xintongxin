              </div>

              <!-- 鍘嗗彶璁板綍鍥捐〃 -->
              <div class="sound-history-chart">
                <canvas id="soundChart" width="600" height="200"></canvas>
              </div>
            </div>

            <!-- 缁熻淇℃伅 -->
            <div class="sound-stats-grid">
              <div class="sound-stat-card">
                <div class="sound-stat-label">骞冲潎澹拌礉</div>
