    { id: 'panda', name: '鐔婄尗', icon: '馃惣', food: '馃帇', breeds: [{ id: 'p1', name: '澶х唺鐚?, icon: '馃惣' }, { id: 'p2', name: '灏忕唺鐚?, icon: '馃惢' }] },
