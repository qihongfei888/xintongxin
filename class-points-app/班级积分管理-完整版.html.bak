  <div id="modalStu" class="modal">
    <div class="modal-inner" style="position:relative">
      <button class="modal-close" onclick="app.closeModal('modalStu')">&times;</button>
      <h3 id="modalStuTitle">娣诲姞瀛︾敓</h3>
      <input type="text" id="stuName" placeholder="濮撳悕 *">
      <input type="text" id="stuNo" placeholder="瀛﹀彿 *">
      <input type="text" id="stuParentPhone" placeholder="瀹堕暱鐢佃瘽锛堥€夊～锛?>
      <input type="text" id="stuAddress" placeholder="瀹跺涵鍦板潃锛堥€夊～锛?>
      <div class="form-row" style="flex-wrap:wrap">
        <label style="min-width:72px">韬珮</label>
        <input type="number" id="stuHeight" placeholder="cm" style="width:90px" min="0">
        <label style="min-width:50px">瑙嗗姏</label>
        <select id="stuVision" style="width:120px">
          <option value="">姝ｅ父</option>
          <option value="杩戣">杩戣</option>
          <option value="闇€鍓嶆帓">闇€鍓嶆帓</option>
        </select>
        <label style="min-width:50px">鎴愮哗</label>
        <input type="number" id="stuScore" placeholder="閫夊～" style="width:90px">
      </div>
      <p style="margin:8px 0">澶村儚</p>
      <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap">
        <div id="avatarPreview" style="width:56px; height:56px; border-radius:50%; overflow:hidden; background:#eee; display:flex; align-items:center; justify-content:center; font-size:2rem;"></div>
        <label class="upload-btn">馃摲 鏈湴涓婁紶澶村儚<input type="file" id="stuAvatarFile" accept="image/*" style="display:none"></label>
      </div>
      <p style="margin:8px 0">鎴栭€?emoji</p>
      <div id="avatarOptions" style="display:flex; flex-wrap:wrap; gap:6px"></div>
      <div class="modal-actions"><button class="btn btn-secondary" onclick="app.closeModal('modalStu')">鍙栨秷</button><button class="btn btn-primary" onclick="app.saveStu()">淇濆瓨</button></div>
    </div>
  </div>

