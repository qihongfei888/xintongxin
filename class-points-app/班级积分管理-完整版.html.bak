                <div class="sound-stat-value" id="monitorDuration">00:00</div>
              </div>
            </div>

            <!-- 澹拌礉绛夌骇璇存槑 -->
            <div class="sound-level-guide">
              <h4>馃搳 澹拌礉绛夌骇鍙傝€?/h4>
              <div class="sound-level-items">
