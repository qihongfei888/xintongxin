    { id: 'dog', name: '鐙楃嫍', icon: '馃悤', food: '馃Υ', breeds: [{ id: 'd1', name: '閲戞瘺', icon: '馃悤' }, { id: 'd2', name: '鏌熀', icon: '馃惗' }, { id: 'd3', name: '鍝堝＋濂?, icon: '馃惡' }, { id: 'd4', name: '娉拌开', icon: '馃惄' }, { id: 'd5', name: '钀ㄦ懇鑰?, icon: '馃Ξ' }] },
